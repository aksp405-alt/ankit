import openai
import speech_recognition as sr
import pyttsx3
import pyaudio
import threading
import time
import os
from flask import Flask, jsonify, request

# ================= CONFIG =================
OPENAI_KEY = "sk-proj-..."  # YAHAN APNA KEY PASTE KAR
openai.api_key = OPENAI_KEY

app = Flask(__name__)

# Voice setup
engine = pyttsx3.init()
voices = engine.getProperty('voices')
engine.setProperty('voice', voices[1].id if len(voices)>1 else voices[0].id)
engine.setProperty('rate', 180)

recognizer = sr.Recognizer()
mic = sr.Microphone()

def speak(text):
    print(f"🤖 AI: {text}")
    engine.say(text)
    engine.runAndWait()

def listen():
    try:
        with mic as source:
            print("🎤 Boliye... (5 sec timeout)")
            recognizer.adjust_for_ambient_noise(source, duration=0.5)
            audio = recognizer.listen(source, timeout=5, phrase_time_limit=10)
        
        # Hindi first, English fallback
        text = recognizer.recognize_google(audio, language='hi-IN')
        print(f"✅ Aap: {text}")
        return text
    except sr.UnknownValueError:
        try:
            text = recognizer.recognize_google(audio, language='en-IN')
            print(f"✅ Aap: {text}")
            return text
        except:
            speak("Samajh nahi aaya, fir se bolo!")
            return None

def ai_reply(message):
    try:
        response = openai.ChatCompletion.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": message}],
            max_tokens=150
        )
        return response.choices[0].message.content
    except Exception as e:
        return f"Error: {e}"

def voice_chat_loop():
    speak("🚀 Voice AI ready! 'bye' bolke band kar sakte ho.")
    while True:
        user_input = listen()
        if not user_input: continue
        
        if any(word in user_input.lower() for word in ['bye', 'exit', 'band', 'stop']):
            speak("ठीक है भाई, मिलते हैं! Bye!")
            break
        
        print("🤔 AI soch raha...")
        reply = ai_reply(user_input)
        speak(reply)
        time.sleep(1)

# Flask web endpoint (bonus)
@app.route('/chat', methods=['POST'])
def web_chat():
    data = request.json
    reply = ai_reply(data['message'])
    return jsonify({'reply': reply})

@app.route('/')
def home():
    return '''
    <h1>🎙️ Voice AI Live!</h1>
    <p>Mic se bolo ya POST /chat pe text bhejo</p>
    '''

if __name__ == '__main__':
    print("🔥 VOICE AI LAUNCHING...")
    print("📱 Web: http://localhost:5000")
    print("🎤 Mic ready in 3 sec...")
    
    # Voice chat background me chalao
    chat_thread = threading.Thread(target=voice_chat_loop, daemon=True)
    chat_thread.start()
    
    # Web server
    app.run(host='0.0.0.0', port=5000, debug=False)
